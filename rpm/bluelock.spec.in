Name:           bluelock
Version:        0
Release:        0%{?dist}
Summary:        Lock and unlock your KDE session based on Bluetooth device proximity

License:        Unlicense
URL:            https://github.com/gunchev/bluelock
Source0:        %{name}-%{version}.tar.gz
Source1:        %{name}.desktop
Source2:        %{name}.svg

BuildArch:      noarch
BuildRequires:  python3-devel
BuildRequires:  pyproject-rpm-macros
BuildRequires:  desktop-file-utils

Requires:       python3
Requires:       python3-pyqt6-base
Requires:       bluez

%description
BlueLock monitors a paired Bluetooth device's signal strength and automatically
locks your KDE desktop session when the device moves out of range, then unlocks
it when the device returns.

Features:
 - System tray icon showing current proximity state
 - Configurable RSSI thresholds with hysteresis to avoid oscillation
 - Configurable time durations before locking/unlocking
 - D-Bus ScreenSaver integration (no extra tools required)
 - Optional custom lock/unlock commands

%prep
%autosetup -p1

%build
%pyproject_wheel

%install
%pyproject_install
%pyproject_save_files bluelock

install -Dpm 0644 %{SOURCE1} %{buildroot}%{_datadir}/applications/%{name}.desktop
install -Dpm 0644 %{SOURCE2} %{buildroot}%{_datadir}/icons/hicolor/scalable/apps/%{name}.svg

%check
desktop-file-validate %{buildroot}%{_datadir}/applications/%{name}.desktop

%files -f %{pyproject_files}
%license LICENSE
%{_bindir}/%{name}
%{_datadir}/applications/%{name}.desktop
%{_datadir}/icons/hicolor/scalable/apps/%{name}.svg

%changelog
